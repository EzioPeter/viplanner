<launch>
    <node pkg="dvf_planner_node" type="dvf_planner_node.py" name="dvf_planner_node" output="screen">
        <rosparam command="load" file="$(find dvf_planner_node)/config/default.yaml"/>
    </node>
    <node type="rviz" name="dvf_planner_rviz" pkg="rviz" args="-d $(find dvf_planner_node)/rviz/default.rviz" respawn="false"/>
</launch>
