<launch>
    <arg name="config"/>
    <arg name="odomTopic" default="/state_estimator/pose_in_odom"/>
    <arg name="commandTopic" default="/local_guidance_path_follower/twist"/>
    <arg name="trackingDis" default="0.5"/>
    <arg name="sensorOffsetX" default="0"/>
    <arg name="sensorOffsetY" default="0"/>

    <include file="$(find dvf_path_follow)/launch/path_follower.launch" >
        <arg name="odomTopic" value="$(arg odomTopic)"/>
        <arg name="commandTopic" value="$(arg commandTopic)"/>
        <arg name="trackingDis" value="$(arg trackingDis)"/>
        <arg name="sensorOffsetX" value="$(arg sensorOffsetX)"/>
        <arg name="sensorOffsetY" value="$(arg sensorOffsetY)"/>
    </include>

    <node pkg="dvf_planner_node" type="dvf_planner_viz.py" name="dvf_planner_node" output="screen">
        <rosparam command="load" file="$(find dvf_planner_node)/config/$(arg config).yaml"/>
    </node>


    <!-- <node type="rviz" name="dvf_planner_rviz" pkg="rviz" args="-d $(find dvf_planner_node)/rviz/default.rviz" respawn="false"/> -->
</launch>