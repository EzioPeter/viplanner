<launch>
    <arg name="config"/>
    <arg name="rosbag" default="false"/>
    <arg name="use_path_follow" default="true"/>

    <group if="$(arg use_path_follow)">
        <include file="$(find vip_path_follower)/launch/$(arg config).launch" />
    </group>

    <node pkg="viplanner_node" type="viplanner_node.py" name="viplanner_node" output="screen">
        <rosparam command="load" file="$(find viplanner_node)/config/$(arg config).yaml"/>
    </node>

    <node pkg="rosbag" type="record" name="rosbag_record" args="record -o $(find viplanner_node)/bag/ /depth_camera_front_upper/point_cloud_self_filtered /depth_camera_front_upper/depth/camera_info /depth_camera_front_upper/depth/image_rect_raw /compslam_lio/odometry /point_cloud_filter/lidar/point_cloud_filtered /state_estimator/pose_in_odom /mp_waypoint /joy" if="$(arg rosbag)" />
    <!-- <node type="rviz" name="dvf_planner_rviz" pkg="rviz" args="-d $(find dvf_planner_node)/rviz/default.rviz" respawn="false"/> -->
</launch>
