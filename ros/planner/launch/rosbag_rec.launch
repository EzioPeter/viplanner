<launch>

    <node pkg="rosbag" type="record" name="rosbag_record" args="record -o $(find viplanner_node)/bag/ /sensors/imu /tf /tf_static /viplanner/timer /m2f_timer /wide_angle_camera_front/camera_info /wide_angle_camera_front/image_raw/compressed /viplanner/status /depth_camera_front_upper/depth/camera_info /depth_camera_front_upper/depth/image_rect_raw /path /mp_waypoint /joy /compslam_lio/odometry /state_estimator/odometry /state_estimator/pose_in_odom /lidar/point_cloud" />
    <!-- <node type="rviz" name="dvf_planner_rviz" pkg="rviz" args="-d $(find dvf_planner_node)/rviz/default.rviz" respawn="false"/> -->
</launch>