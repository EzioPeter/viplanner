<launch>
    <arg name="config_viplanner"     default="anymal_c"/>
    <arg name="use_path_follow"      default="true"/>
    <arg name="enable_visualization" default="false"/>

    <group if="$(arg use_path_follow)">
        <include file="$(find path_follower)/launch/path_follower.launch" />
        <!-- <include file="$(find ps3joy)/launch/ps3.launch" /> -->
    </group>

    <group if="$(arg enable_visualization)">
        <include file="$(find viplanner_viz)/launch/viplannerViz.launch" />
    </group>

    <!-- <group if="$(eval config_viplanner == 'anymal_mount')">
        <node pkg="tf" type="static_transform_publisher" name="mount_depth_tf" args="0 0 0 0 0 0 /depth_cam_mounted_front_depth_optical_frame /wide_angle_camera_front_camera_parent 100"/>
        <node pkg="tf" type="static_transform_publisher" name="mount_rgb_tf" args="0 0 0 0 0 0 /depth_cam_mounted_front_color_optical_frame /wide_angle_camera_front_camera_parent 100"/>
    </group> -->

    <!-- VIPlanner Node to generate waypoints using depth and semantic input information -->
    <node pkg="viplanner_node" type="viplanner_node.py" name="viplanner_node" output="screen">
        <rosparam command="load" file="$(find viplanner_node)/config/$(arg config_viplanner).yaml"/>
        <param name="mount_cam_frame" type="string" value="wide_angle_camera_rear_camera_parent"/>
    </node>

    <!-- <node type="rviz" name="dvf_planner_rviz" pkg="rviz" args="-d $(find dvf_planner_node)/rviz/default.rviz" respawn="false"/> -->
</launch>
